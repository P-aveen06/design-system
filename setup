#!/usr/bin/env bash
# Setup script for the design-system Claude skill.
# Verifies install location, makes the HTML easy to open, prints next steps.

set -e

DIM='\033[2m'
BOLD='\033[1m'
GREEN='\033[32m'
YELLOW='\033[33m'
RESET='\033[0m'

SKILL_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
EXPECTED_DIR="$HOME/.claude/skills/design-system"
HTML_FILE="$SKILL_DIR/design-system.html"

echo ""
echo -e "${BOLD}Design System — Claude skill setup${RESET}"
echo -e "${DIM}────────────────────────────────────${RESET}"

# 1. Verify install location
if [ "$SKILL_DIR" != "$EXPECTED_DIR" ]; then
  echo -e "${YELLOW}⚠${RESET}  Installed at: $SKILL_DIR"
  echo -e "   Claude Code looks for skills at: $EXPECTED_DIR"
  echo -e "   ${DIM}Reinstall with:${RESET}"
  echo -e "   ${DIM}  rm -rf \"$SKILL_DIR\" && git clone --branch main --single-branch --depth 1 https://github.com/P-aveen06/design-system.git \"$EXPECTED_DIR\"${RESET}"
  echo ""
  exit 1
fi
echo -e "${GREEN}✓${RESET} Installed at $SKILL_DIR"

# 2. Verify the core file exists
if [ ! -f "$HTML_FILE" ]; then
  echo -e "${YELLOW}⚠${RESET}  design-system.html not found at $HTML_FILE"
  exit 1
fi
echo -e "${GREEN}✓${RESET} design-system.html present"

# 3. Verify SKILL.md is in place (it's what Claude Code discovers)
if [ ! -f "$SKILL_DIR/SKILL.md" ]; then
  echo -e "${YELLOW}⚠${RESET}  SKILL.md not found — Claude Code won't discover this skill"
  exit 1
fi
echo -e "${GREEN}✓${RESET} SKILL.md present"

# 4. Open the HTML in the default browser so the user can customize
echo ""
echo -e "Opening design-system.html in your browser…"
if command -v open >/dev/null 2>&1; then
  open "$HTML_FILE"
elif command -v xdg-open >/dev/null 2>&1; then
  xdg-open "$HTML_FILE"
else
  echo -e "${DIM}  (could not auto-open; visit file://$HTML_FILE manually)${RESET}"
fi

# 5. Next steps
echo ""
echo -e "${BOLD}Next steps${RESET}"
echo -e "  1. Customize your theme in the browser (controls panel on the right)."
echo -e "  2. Hit ${BOLD}Save${RESET} when you're happy."
echo -e "  3. In any Claude Code session, ask Claude to build UI — it will"
echo -e "     automatically reference your design system as the source of truth."
echo ""
echo -e "${DIM}You can also invoke it explicitly with:${RESET} /design-system"
echo ""
